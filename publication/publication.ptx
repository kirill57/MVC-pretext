<?xml version="1.0" encoding="UTF-8"?>
<!-- Publication file for Multi-Variable Calculus (PreTeXt).               -->
<!-- Docs: https://pretextbook.org/doc/guide/html/publisher-file-reference.html -->
<publication>
  <common>
    <tableofcontents level="2"/>
  </common>

  <source>
    <directories external="../assets" generated="../generated-assets"/>
  </source>

  <numbering>
    <!-- Parts are decorative: chapters numbered 1..20 continuously across parts. -->
    <!-- With parts present, the part counts as a numbering level, so chapter is  -->
    <!-- level 2 and section is level 3.  level="3" => number chapters AND sections. -->
    <divisions part-structure="decorative" level="3"/>
    <blocks level="3"/>
    <equations level="3"/>
    <projects level="3"/>
    <footnotes level="3"/>
  </numbering>

  <latex/>

  <html>
    <css theme="default-modern"/>
    <toc focused="yes" preexpanded-levels="1"/>
  </html>

  <epub/>
</publication>
