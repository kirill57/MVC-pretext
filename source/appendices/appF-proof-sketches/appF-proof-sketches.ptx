<?xml version="1.0" encoding="UTF-8"?>
<appendix xml:id="appF-proof-sketches" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Proof Sketches and Theorem Dependencies</title>

  <introduction>
    <p>
      This appendix records why the main theorems are true and which earlier facts they use.
      It is not a full proof chapter. It is a map of the logic.
    </p>
    <p>
      Each entry gives:
    </p>
    <table xml:id="tab-appF-entry-structure">
      <title>What each entry records.</title>
      <tabular>
        <row header="yes" bottom="medium">
          <cell>Item</cell>
          <cell>Meaning</cell>
        </row>
        <row>
          <cell>Statement</cell>
          <cell>the theorem in compact form</cell>
        </row>
        <row>
          <cell>Hypotheses</cell>
          <cell>the assumptions that make the theorem safe</cell>
        </row>
        <row>
          <cell>Proof idea</cell>
          <cell>the main mechanism behind the proof</cell>
        </row>
        <row>
          <cell>Dependencies</cell>
          <cell>earlier facts used</cell>
        </row>
        <row>
          <cell>What can fail</cell>
          <cell>why the hypotheses are not decoration</cell>
        </row>
      </tabular>
    </table>
    <table xml:id="tab-appF-main-sources">
      <title>The main source of each theorem's proof.</title>
      <tabular>
        <row header="yes" bottom="medium">
          <cell>Theorem</cell>
          <cell>Main source of the proof</cell>
        </row>
        <row>
          <cell>Differentiability from continuous partials</cell>
          <cell>single-variable FTC along coordinate steps</cell>
        </row>
        <row>
          <cell>Equality of mixed partials</cell>
          <cell>two orders of measuring rectangle change</cell>
        </row>
        <row>
          <cell>Fubini</cell>
          <cell>slice sums</cell>
        </row>
        <row>
          <cell>Change of variables</cell>
          <cell>local linearization and determinant scaling</cell>
        </row>
        <row>
          <cell>Green</cell>
          <cell>small rectangles and cancellation</cell>
        </row>
        <row>
          <cell>Stokes</cell>
          <cell>pull back to Green's theorem</cell>
        </row>
        <row>
          <cell>Divergence theorem</cell>
          <cell>small boxes and cancellation</cell>
        </row>
        <row>
          <cell>Generalized Stokes</cell>
          <cell>boundary cancellation in oriented cells</cell>
        </row>
      </tabular>
    </table>
  </introduction>

  <xi:include href="sections/sec-appF-differentiability-and-continuous-partial-derivatives.xml"/>
  <xi:include href="sections/sec-appF-equality-of-mixed-partials.xml"/>
  <xi:include href="sections/sec-appF-fubini-s-theorem-and-change-of-variables.xml"/>
  <xi:include href="sections/sec-appF-green-s-theorem.xml"/>
  <xi:include href="sections/sec-appF-stokes-theorem.xml"/>
  <xi:include href="sections/sec-appF-divergence-theorem.xml"/>
  <xi:include href="sections/sec-appF-generalized-stokes-theorem.xml"/>
  <xi:include href="sections/sec-appF-dependency-chart.xml"/>
  <xi:include href="sections/sec-appF-one-page-theorem-summary.xml"/>

</appendix>
