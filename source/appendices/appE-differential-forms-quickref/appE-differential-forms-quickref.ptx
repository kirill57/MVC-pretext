<?xml version="1.0" encoding="UTF-8"?>
<appendix xml:id="appE-differential-forms-quickref" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Differential Forms Quick Reference</title>

  <introduction>
    <p>
      Differential forms are integrands with orientation built in. A <m>1</m>-form is built for
      curves. A <m>2</m>-form is built for surfaces. A <m>3</m>-form is built for solids.
    </p>
    <p>
      This appendix is a reference. It is meant to be scanned.
    </p>
    <table xml:id="tab-appE-forms-overview">
      <title>Forms by degree, what they integrate over, and their typical meaning.</title>
      <tabular>
        <row header="yes" bottom="medium">
          <cell>Form</cell>
          <cell>Integrated over</cell>
          <cell>Typical meaning</cell>
        </row>
        <row>
          <cell><m>0</m>-form</cell>
          <cell>points</cell>
          <cell>function value</cell>
        </row>
        <row>
          <cell><m>1</m>-form</cell>
          <cell>curves</cell>
          <cell>work, circulation</cell>
        </row>
        <row>
          <cell><m>2</m>-form</cell>
          <cell>surfaces</cell>
          <cell>flux, signed area</cell>
        </row>
        <row>
          <cell><m>3</m>-form</cell>
          <cell>solids</cell>
          <cell>density, signed volume</cell>
        </row>
      </tabular>
    </table>
  </introduction>

  <xi:include href="sections/sec-appE-0-forms-1-forms-2-forms-and.xml"/>
  <xi:include href="sections/sec-appE-wedge-product-rules.xml"/>
