  <md>f'(a)\approx\frac{f(a+h)-f(a-h)}{2h}</md>

  <md>f_x(a,b)\approx\frac{f(a+h,b)-f(a-h,b)}{2h}</md>

  <md>J_F(\mathbf p)_{ij}\approx\frac{F_i(\mathbf p+h\mathbf e_j)-F_i(\mathbf p-h\mathbf e_j)}{2h}</md>

  <md>\iint_R f\,dA\approx\sum f(x_i^*,y_j^*)\,\Delta x\,\Delta y</md>

  <md>dA=r\,dr\,d\theta</md>

  <md>dV=r\,dr\,d\theta\,dz</md>

  <md>dV=\rho^2\sin\phi\,d\rho\,d\phi\,d\theta</md>

  <md>\int_C P\,dx+Q\,dy+R\,dz=\int_a^b(Px'+Qy'+Rz')\,dt</md>

  <md>\iint_S\mathbf F\cdot\widehat{\mathbf n}\,dS=\iint_D\mathbf F(\mathbf r(u,v))\cdot(\mathbf r_u\times\mathbf r_v)\,du\,dv</md>

  <md>\mathbf r'=\mathbf F(\mathbf r)</md>

  <md>\rho_t+\nabla\cdot\mathbf J=s</md>

  <md>\frac{d}{dt}\int_E\rho\,dV=-\int_{\partial E}\mathbf J\cdot\widehat{\mathbf n}\,dS+\int_E s\,dV</md>
