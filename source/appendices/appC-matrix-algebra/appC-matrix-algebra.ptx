<?xml version="1.0" encoding="UTF-8"?>
<appendix xml:id="appC-matrix-algebra" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Matrix Algebra Quick Reference</title>

  <introduction>
    <p>
      Matrices are the bookkeeping language for linear maps. In this book they appear as
      linear transformations, Jacobian matrices, Hessian matrices, coordinate changes, and
      quadratic forms.
    </p>
    <p>
      This appendix is a reference. It is meant to be scanned.
    </p>
    <table xml:id="tab-appC-matrix-ideas">
      <title>Where each matrix idea appears in the book.</title>
      <tabular>
        <row header="yes" bottom="medium">
          <cell>Matrix idea</cell>
          <cell>Where it appears in the book</cell>
        </row>
        <row>
          <cell>matrix multiplication</cell>
          <cell>composition of linear maps</cell>
        </row>
        <row>
          <cell>row reduction</cell>
          <cell>solving linear systems</cell>
        </row>
        <row>
          <cell>determinant</cell>
          <cell>area, volume, orientation, Jacobians</cell>
        </row>
        <row>
          <cell>inverse matrix</cell>
          <cell>undoing a linear map</cell>
        </row>
        <row>
          <cell>eigenvalues</cell>
          <cell>principal directions, quadratic forms</cell>
        </row>
        <row>
          <cell>quadratic forms</cell>
          <cell>Hessian test, conics, local shape</cell>
        </row>
      </tabular>
    </table>
  </introduction>

  <xi:include href="sections/sec-appC-matrix-operations.xml"/>
  <xi:include href="sections/sec-appC-row-reduction.xml"/>
  <xi:include href="sections/sec-appC-determinants.xml"/>
  <xi:include href="sections/sec-appC-inverse-matrices.xml"/>
  <xi:include href="sections/sec-appC-eigenvalues-and-eigenvectors.xml"/>
  <xi:include href="sections/sec-appC-quadratic-forms.xml"/>
  <xi:include href="sections/sec-appC-one-page-formula-summary.xml"/>

</appendix>
