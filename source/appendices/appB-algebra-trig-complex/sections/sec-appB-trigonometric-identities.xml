<section xml:id="sec-appB-trigonometric-identities" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Trigonometric identities</title>

  <subsection xml:id="appB-trig-unit-circle">
    <title>Unit circle</title>

    <p>
      On the unit circle,
      <md>(\cos\theta,\sin\theta)</md>
      is the point at angle <m>\theta</m>.
    </p>

    <p>
      <md>\cos^2\theta+\sin^2\theta=1.</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-radians">
    <title>Radians</title>

    <p>
      <md>2\pi\text{ radians}=360^\circ.</md>
    </p>

    <p>
      <md>\pi\text{ radians}=180^\circ.</md>
    </p>

    <p>
      <md>s=r\theta</md>
      where <m>s</m> is arc length, <m>r</m> is radius, and <m>\theta</m> is measured in radians.
    </p>
  </subsection>

  <subsection xml:id="appB-trig-common-angles">
    <title>Common angles</title>

    <table xml:id="appB-trig-table-common-angles">
      <title>Cosine and sine at common angles.</title>
