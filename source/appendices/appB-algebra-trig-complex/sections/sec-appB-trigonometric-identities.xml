  </subsection>

  <subsection xml:id="appB-trig-signs-by-quadrant">
    <title>Signs by quadrant</title>

    <table xml:id="appB-trig-table-signs-by-quadrant">
      <title>Signs of cosine and sine in each quadrant.</title>
      <tabular halign="center">
        <row bottom="minor">
          <cell>Quadrant</cell>
          <cell><m>\cos\theta</m></cell>
          <cell><m>\sin\theta</m></cell>
        </row>
        <row>
          <cell><m>\text{I}</m></cell>
          <cell><m>+</m></cell>
          <cell><m>+</m></cell>
        </row>
        <row>
          <cell><m>\text{II}</m></cell>
          <cell><m>-</m></cell>
          <cell><m>+</m></cell>
        </row>
        <row>
          <cell><m>\text{III}</m></cell>
          <cell><m>-</m></cell>
          <cell><m>-</m></cell>
        </row>
        <row>
          <cell><m>\text{IV}</m></cell>
          <cell><m>+</m></cell>
          <cell><m>-</m></cell>
        </row>
      </tabular>
    </table>
  </subsection>

  <subsection xml:id="appB-trig-other-functions">
    <title>Other trigonometric functions</title>

    <p>
      <md>\tan\theta=\frac{\sin\theta}{\cos\theta}</md>
    </p>

    <p>
      <md>\sec\theta=\frac1{\cos\theta}</md>
    </p>

    <p>
      <md>\csc\theta=\frac1{\sin\theta}</md>
    </p>

    <p>
      <md>\cot\theta=\frac{\cos\theta}{\sin\theta}</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-pythagorean-identities">
    <title>Pythagorean identities</title>

    <p>
      <md>\sin^2\theta+\cos^2\theta=1</md>
    </p>

    <p>
      <md>1+\tan^2\theta=\sec^2\theta</md>
    </p>

    <p>
      <md>1+\cot^2\theta=\csc^2\theta</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-even-and-odd-identities">
    <title>Even and odd identities</title>

    <p>
      <md>\cos(-\theta)=\cos\theta</md>
    </p>

    <p>
      <md>\sin(-\theta)=-\sin\theta</md>
    </p>

    <p>
      <md>\tan(-\theta)=-\tan\theta</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-periodicity">
    <title>Periodicity</title>

    <p>
      <md>\sin(\theta+2\pi)=\sin\theta</md>
    </p>

    <p>
      <md>\cos(\theta+2\pi)=\cos\theta</md>
    </p>

    <p>
      <md>\tan(\theta+\pi)=\tan\theta</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-angle-addition-formulas">
    <title>Angle addition formulas</title>

    <p>
      <md>\cos(\alpha+\beta)=\cos\alpha\cos\beta-\sin\alpha\sin\beta</md>
    </p>

    <p>
      <md>\sin(\alpha+\beta)=\sin\alpha\cos\beta+\cos\alpha\sin\beta</md>
    </p>

    <p>
      <md>\cos(\alpha-\beta)=\cos\alpha\cos\beta+\sin\alpha\sin\beta</md>
    </p>

    <p>
      <md>\sin(\alpha-\beta)=\sin\alpha\cos\beta-\cos\alpha\sin\beta</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-double-angle-formulas">
    <title>Double-angle formulas</title>

    <p>
      <md>\sin(2\theta)=2\sin\theta\cos\theta</md>
    </p>

    <p>
      <md>\cos(2\theta)=\cos^2\theta-\sin^2\theta</md>
    </p>

    <p>
      <md>\cos(2\theta)=2\cos^2\theta-1</md>
    </p>

    <p>
      <md>\cos(2\theta)=1-2\sin^2\theta</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-half-angle-identities">
    <title>Half-angle identities</title>

    <p>
      <md>\cos^2\theta=\frac{1+\cos(2\theta)}{2}</md>
    </p>

    <p>
      <md>\sin^2\theta=\frac{1-\cos(2\theta)}{2}</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-useful-shifts">
    <title>Useful shifts</title>

    <p>
      <md>\cos(\theta+\pi)=-\cos\theta</md>
    </p>

    <p>
      <md>\sin(\theta+\pi)=-\sin\theta</md>
    </p>

    <p>
      <md>\cos\left(\theta+\frac{\pi}{2}\right)=-\sin\theta</md>
    </p>

    <p>
      <md>\sin\left(\theta+\frac{\pi}{2}\right)=\cos\theta</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-inverse-trig-derivatives">
    <title>Inverse trig derivatives</title>

    <p>
      <md>\frac{d}{dx}\sin^{-1}x=\frac1{\sqrt{1-x^2}}</md>
    </p>

    <p>
      <md>\frac{d}{dx}\cos^{-1}x=-\frac1{\sqrt{1-x^2}}</md>
    </p>

    <p>
      <md>\frac{d}{dx}\tan^{-1}x=\frac1{1+x^2}</md>
    </p>
  </subsection>

  <subsection xml:id="appB-trig-polar-conversion">
    <title>Polar conversion</title>

    <p>
      <md>x=r\cos\theta,\qquad y=r\sin\theta.</md>
    </p>

    <p>
      <md>r^2=x^2+y^2.</md>
    </p>

    <p>
      <md>\tan\theta=\frac yx</md>
      with quadrant care.
    </p>
  </subsection>

  <subsection xml:id="appB-trig-common-warnings">
    <title>Common warnings</title>

    <warning>
      <p>Radians are the default in calculus.</p>

      <p>
        <md>\sin^2\theta</md>
        means
        <md>(\sin\theta)^2,</md>
        not
        <md>\sin(\theta^2).</md>
      </p>

      <p>
        The equation
        <md>\tan\theta=\frac yx</md>
        does not determine the quadrant by itself.
      </p>
    </warning>
  </subsection>
</section>
