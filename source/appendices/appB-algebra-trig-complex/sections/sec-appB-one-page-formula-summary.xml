<section xml:id="sec-appB-one-page-formula-summary" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>One-page formula summary</title>

  <p>
    <md>
      <mrow>\boxed{a^2-b^2=(a-b)(a+b)}</mrow>
      <mrow>\boxed{x=\frac{-b\pm\sqrt{b^2-4ac}}{2a}}</mrow>
      <mrow>\boxed{|a+b|\le |a|+|b|}</mrow>
      <mrow>\boxed{\sin^2\theta+\cos^2\theta=1}</mrow>
      <mrow>\boxed{\cos(\alpha+\beta)=\cos\alpha\cos\beta-\sin\alpha\sin\beta}</mrow>
      <mrow>\boxed{\sin(\alpha+\beta)=\sin\alpha\cos\beta+\cos\alpha\sin\beta}</mrow>
      <mrow>\boxed{x=r\cos\theta,\qquad y=r\sin\theta}</mrow>
      <mrow>\boxed{z=a+bi}</mrow>
      <mrow>\boxed{i^2=-1}</mrow>
      <mrow>\boxed{|a+bi|=\sqrt{a^2+b^2}}</mrow>
      <mrow>\boxed{\overline{a+bi}=a-bi}</mrow>
      <mrow>\boxed{z\overline z=|z|^2}</mrow>
      <mrow>\boxed{z=r(\cos\theta+i\sin\theta)=re^{i\theta}}</mrow>
      <mrow>\boxed{e^{i\theta}=\cos\theta+i\sin\theta}</mrow>
      <mrow>\boxed{(re^{i\theta})^n=r^n e^{in\theta}}</mrow>
      <mrow>\boxed{z^n=Re^{i\Theta}\quad\Longrightarrow\quad z_k=R^{1/n}e^{i(\Theta+2\pi k)/n}}</mrow>
      <mrow>\boxed{z^n=1\quad\Longrightarrow\quad z_k=e^{2\pi i k/n}}</mrow>
    </md>
  </p>
</section>
