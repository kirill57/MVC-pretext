<?xml version="1.0" encoding="UTF-8"?>
<appendix xml:id="appB-algebra-trig-complex" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Algebra, Trigonometry, and Complex Numbers Quick Reference</title>

  <introduction>
    <p>
      This appendix collects the algebra, trigonometry, and complex-number facts used in the
      book. It is meant to be scanned.
    </p>
    <table xml:id="tab-appB-tools-where-they-appear">
      <title>Where each algebraic and trigonometric tool appears in the book.</title>
      <tabular>
        <row header="yes" bottom="medium">
          <cell>Tool</cell>
          <cell>Where it appears</cell>
        </row>
        <row>
          <cell>factoring</cell>
          <cell>limits, domains, singularities</cell>
        </row>
        <row>
          <cell>completing the square</cell>
          <cell>circles, ellipses, quadratic forms</cell>
        </row>
        <row>
          <cell>inequalities</cell>
          <cell>estimates, domains, convergence</cell>
        </row>
        <row>
          <cell>trigonometry</cell>
          <cell>polar, cylindrical, spherical coordinates</cell>
        </row>
        <row>
          <cell>complex numbers</cell>
          <cell>plane rotations and roots</cell>
        </row>
        <row>
          <cell>Euler's formula</cell>
          <cell>oscillation, rotation, roots of unity</cell>
        </row>
      </tabular>
    </table>
  </introduction>

  <xi:include href="sections/sec-appB-algebraic-manipulation-and-inequalities.xml"/>
  <xi:include href="sections/sec-appB-trigonometric-identities.xml"/>
  <xi:include href="sections/sec-appB-complex-numbers-and-rotations.xml"/>
  <xi:include href="sections/sec-appB-euler-s-formula.xml"/>
  <xi:include href="sections/sec-appB-complex-roots-and-geometry.xml"/>
  <xi:include href="sections/sec-appB-one-page-formula-summary.xml"/>

</appendix>
