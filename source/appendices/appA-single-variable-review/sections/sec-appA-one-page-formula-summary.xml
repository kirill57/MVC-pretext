<section xml:id="sec-appA-one-page-formula-summary" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>One-page formula summary</title>

  <subsection xml:id="subsec-appA-sum-derivatives-and-linear-approximation">
    <title>Derivatives and linear approximation</title>
    <md>\boxed{f'(a)=\lim_{h\to0}\frac{f(a+h)-f(a)}{h}}</md>
    <md>\boxed{L(x)=f(a)+f'(a)(x-a)}</md>
    <md>\boxed{df=f'(x)\,dx}</md>
  </subsection>

  <subsection xml:id="subsec-appA-sum-integration">
    <title>Integration</title>
    <md>\boxed{\int_a^b F'(x)\,dx=F(b)-F(a)}</md>
    <md>\boxed{\int f(g(x))g'(x)\,dx=\int f(u)\,du}</md>
    <md>\boxed{\int u\,dv=uv-\int v\,du}</md>
  </subsection>

  <subsection xml:id="subsec-appA-sum-parametric-and-polar">
    <title>Parametric and polar curves</title>
    <md>\boxed{L_{\text{curve}}=\int_a^b|\mathbf r'(t)|\,dt}</md>
    <md>\boxed{A_{\text{polar}}=\frac12\int_\alpha^\beta r^2\,d\theta}</md>
  </subsection>

  <subsection xml:id="subsec-appA-sum-series-and-taylor">
    <title>Series and Taylor polynomials</title>
    <md>\boxed{\sum_{n=0}^{\infty}ar^n=\frac{a}{1-r}\quad (|r|\lt 1)}</md>
    <md>\boxed{T_n(x)=\sum_{k=0}^{n}\frac{f^{(k)}(a)}{k!}(x-a)^k}</md>
  </subsection>

  <subsection xml:id="subsec-appA-sum-boundary-formulation">
    <title>The fundamental theorem as a boundary statement</title>
    <md>\boxed{\partial[a,b]=\{b\}-\{a\}}</md>
    <md>\boxed{\int_{[a,b]}dF=\int_{\partial[a,b]}F}</md>
  </subsection>
</section>
