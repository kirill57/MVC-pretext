<?xml version="1.0" encoding="UTF-8"?>
<appendix xml:id="appA-single-variable-review" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Single-Variable Calculus Quick Reference</title>

  <introduction>
    <p>
      This appendix is a reference for the single-variable facts used throughout the book.
      It is meant to be scanned, not read like a chapter.
    </p>
    <table xml:id="tab-appA-singlevar-to-multivar">
      <title>How single-variable ideas reappear in several variables.</title>
      <tabular>
        <row header="yes" bottom="medium">
          <cell>Single-variable idea</cell>
          <cell>Multivariable version</cell>
        </row>
        <row>
          <cell>derivative</cell>
          <cell>partial derivative, directional derivative, differential</cell>
        </row>
        <row>
          <cell>linear approximation</cell>
          <cell>tangent plane, Jacobian matrix</cell>
        </row>
        <row>
          <cell>substitution</cell>
          <cell>change of variables, pullback</cell>
        </row>
        <row>
          <cell>definite integral</cell>
          <cell>double, triple, line, and surface integrals</cell>
        </row>
        <row>
          <cell>Fundamental Theorem of Calculus</cell>
          <cell>Green, Stokes, divergence, generalized Stokes</cell>
        </row>
      </tabular>
    </table>
  </introduction>

  <xi:include href="sections/sec-appA-limits-and-continuity.xml"/>
  <xi:include href="sections/sec-appA-derivatives-and-linear-approximation.xml"/>
  <xi:include href="sections/sec-appA-the-fundamental-theorem-of-calculus.xml"/>
  <xi:include href="sections/sec-appA-substitution-and-integration-by-parts.xml"/>
  <xi:include href="sections/sec-appA-parametric-and-polar-curves.xml"/>
  <xi:include href="sections/sec-appA-infinite-series-and-taylor-polynomials.xml"/>
  <xi:include href="sections/sec-appA-one-page-formula-summary.xml"/>

</appendix>
